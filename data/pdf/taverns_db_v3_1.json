  "integration": {
    "merge_order": [
      "core",
      "specials[biome]"
    ],
    "merge_rules": {
      "append_lists": [
        "locations",
        "ambience",
        "events",
        "staff_archetypes"
      ],
      "menu_merge": "core.menu + specials[biome].menu_additions (по категориям)",
      "owners": "используй core.owners; при желании добавь биом-специфичных владельцев",
      "constraints": "объединяй, избегая дубликатов пар"
    },
    "sampling": {
      "rarity_weighting": "используй weights.rarity",
      "tag_boost": "если item.tags ∩ biome_tags != ∅, вес *= (1 + weights.tag_boost * count)"
    },
    "pricing_application": {
      "input_params": [
        "base_price",
        "biome",
        "settlement_size",
        "season",
        "tags",
        "is_happy_hour"
      ],
      "pseudo_code": [
        "mult = economy.settlement_size_multipliers[settlement_size]",
        "mult *= economy.biome_price_adjustments[biome]",
        "if season in economy.seasonal_modifiers and biome in economy.seasonal_modifiers[season]:",
        "    mult *= economy.seasonal_modifiers[season][biome]",
        "for t in tags: mult *= economy.scarcity_rules.get(t, 1.0)",
        "if is_happy_hour and economy.happy_hour.enabled: mult *= economy.happy_hour.discount",
        "final = apply_mult_to_price(base_price, mult)",
        "return round_to_nearest_coin(final)"
      ],
      "notes_ru": "Применяйте множители к базовой цене каждого блюда/напитка, затем округляйте."
    }
  },
  "cursor_instructions": {
    "what_is_this": "JSON для двухступенчатой генерации таверн: сначала ядро, затем спец‑данные по местности (биому).",
    "how_to_use": [
      "1) Загрузите JSON и распарсьте в объект db.",
      "2) Выберите biome из specials (city, forest, coastal, mountain, desert, tundra, underground, swamp, roadside).",
      "3) Соберите пул = core + specials[biome]: списки объединяются, меню дополняется через menu_additions.",
      "4) Взвешивайте выбор с weights.rarity и tag_boost по совпадающим тегам.",
      "5) Сформируйте DRAFT (имя, локация, владелец, персонал, атмосфера, меню, комнаты, события, игры) и передайте в LLM.",
      "6) Учитывайте constraints; при конфликте перегенерируйте проблемный блок.",
      "7) После интеграции удалите cursor_instructions."
    ],
    "draft_shape_hint": {
      "name": "string",
      "location": "object",
      "owner": "object",
      "staff": "array",
      "ambience": "object|array",
      "menu": "object",
      "rooms": "array",
      "events": "array",
      "games": "object"
    },
    "llm_hint": "Просите 600–900 слов, соблюдение фактов из DRAFT, кинематографичный тон без перегруза."
  },
  "economy": {
    "currency": {
      "cp_per_sp": 10,
      "sp_per_gp": 10
    },
    "settlement_size_multipliers": {
      "hamlet": 0.8,
      "village": 0.9,
      "town": 1.0,
      "city": 1.15,
      "capital": 1.3
    },
    "biome_price_adjustments": {
      "city": 1.05,
      "forest": 1.0,
      "coastal": 0.95,
      "mountain": 1.2,
      "desert": 1.25,
      "tundra": 1.15,
