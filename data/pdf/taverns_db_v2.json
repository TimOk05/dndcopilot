  "integration": {
    "merge_order": [
      "core",
      "specials[biome]"
    ],
    "merge_rules": {
      "append_lists": [
        "locations",
        "ambience",
        "events",
        "staff_archetypes"
      ],
      "menu_merge": "core.menu + specials[biome].menu_additions (по категориям)",
      "owners": "используй core.owners; при желании добавь биом-специфичных владельцев",
      "constraints": "объединяй, избегая дубликатов пар"
    },
    "sampling": {
      "rarity_weighting": "используй weights.rarity",
      "tag_boost": "если item.tags ∩ biome_tags != ∅, вес *= (1 + weights.tag_boost * count)"
    }
  },
  "cursor_instructions": {
    "what_is_this": "JSON для двухступенчатой генерации таверн: сначала случайный набор по ядру, затем подключение спец-данных по местности (биому).",
    "how_to_use": [
      "1) Загрузите JSON и распарсьте его как объект db.",
      "2) Выберите biome из ключей specials (например: city, forest, coastal, mountain, desert, tundra, underground, swamp, roadside).",
      "3) Соберите пул выбора = core + specials[biome]: списки объединяются, меню дополняется через menu_additions.",
      "4) При взвешенном выборе применяйте weights.rarity и tag_boost к элементам, у которых теги совпадают с tags выбранного биома.",
      "5) Сформируйте DRAFT JSON (имя, локация, владелец, персонал, атмосфера, меню, комнаты, события, игры) и передайте в LLM с вашим промптом.",
      "6) Соблюдайте constraints.exclusive_tags / required_together; при конфликте перегенерируйте проблемный блок.",
      "7) После интеграции удалите поле cursor_instructions."
    ],
